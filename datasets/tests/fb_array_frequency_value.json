      "input": {
        "a": [
          5,
          5,
          5
        ],
        "n": 3,
        "x": 5
      },
      "expected": 3
    },
    {
      "kind": "positive",
      "input": {
        "a": [],
        "n": 0,
        "x": 1
      },
      "expected": 0
    }
  ],
